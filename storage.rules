rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Allow authenticated users to read and write reels
    match /reels/{allPaths=**} {
      allow read, write: if request.auth != null;
    }
    
    // Deny access to other paths
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}