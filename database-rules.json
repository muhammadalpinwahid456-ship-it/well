{
  "rules": {
    ".read": "auth != null",
    ".write": "auth != null",
    "streaks": {
      "$chatId": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    },
    "doodles": {
      "$chatId": {
        "$drawNode": {
          ".read": "auth != null",
          ".write": "auth != null && ($drawNode === ('draw_' + auth.uid) || root.child('doodles').child($chatId).child($drawNode).child('from').val() === auth.uid)"
        }
      }
    }
  }
}
